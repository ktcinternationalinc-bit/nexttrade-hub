# ============================================================
# Living Companion Server — environment variables
# Copy this file to `.env` for local dev and fill in real values.
# On Railway/Render, set these in the dashboard, NOT in git.
# ============================================================

# Where the server listens. Railway/Render usually inject PORT.
PORT=3001

# Origin allowlist for Socket.io CORS. Comma-separated.
# Local dev typically needs http://localhost:3000. Production should
# list the Vercel domain serving your Next.js frontend.
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.vercel.app

# === Provider API keys ===
DEEPGRAM_API_KEY=__set_in_railway_dashboard__
ANTHROPIC_API_KEY=__set_in_railway_dashboard__
ELEVENLABS_API_KEY=__set_in_railway_dashboard__

# === Provider tuning ===
# Deepgram model. Nova-2 is the default per the spec.
DEEPGRAM_MODEL=nova-2

# Claude model — sonnet for reasoning, haiku for low-latency turns.
# Anthropic provides claude-sonnet-4-5 and claude-haiku-4-5 as of writing;
# Adjust to whatever your account has access to.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ElevenLabs voice IDs per persona. Set these from your ElevenLabs library.
ELEVENLABS_VOICE_NADIA=__nadia_voice_id__
ELEVENLABS_VOICE_JENNA=__jenna_voice_id__
ELEVENLABS_VOICE_SARA=__sara_voice_id__

# ElevenLabs streaming model. eleven_turbo_v2_5 gives the lowest latency
# for English; eleven_multilingual_v2 covers Arabic but is slower.
ELEVENLABS_MODEL=eleven_turbo_v2_5
